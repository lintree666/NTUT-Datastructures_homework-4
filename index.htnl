<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HW3-1 智能派單 - 手動操作版</title>
    <style>
        :root {
            --bg-color: #1e1e2e;
            --panel-bg: #282a36;
            --text-color: #f8f8f2;
            --accent: #bd93f9;
            --gold: #f1fa8c;
            --success: #50fa7b;
            --error: #ff5555;
            --warning: #ffb86c;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        h1 {
            color: var(--accent);
            text-align: center;
        }

        .dashboard {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
            width: 100%;
            max-width: 800px;
        }

        .status-panel {
            background-color: var(--panel-bg);
            padding: 20px;
            border-radius: 10px;
            flex: 1;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
            text-align: center;
        }

        .gold-display {
            font-size: 24px;
            font-weight: bold;
            color: var(--gold);
        }

        .action-panel {
            background-color: var(--panel-bg);
            padding: 20px;
            border-radius: 10px;
            width: 100%;
            max-width: 800px;
            margin-bottom: 20px;
            box-sizing: border-box;
            text-align: center;
        }

        .action-panel h3 {
            margin-top: 0;
            color: var(--warning);
        }

        .button-group {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
        }

        button {
            padding: 12px 20px;
            font-size: 16px;
            cursor: pointer;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            transition: 0.2s;
            background-color: #44475a;
            color: white;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        button:hover { background-color: #6272a4; transform: translateY(-2px); }
        button:active { transform: translateY(0); }

        .btn-skip { background-color: #8be9fd; color: #282a36; }
        .btn-skip:hover { background-color: #a4ffff; }
        
        .btn-reset { background-color: var(--error); color: white; margin-left: auto; }
        .btn-reset:hover { background-color: #ff6e6e; }

        .factory-container {
            display: flex;
            justify-content: space-around;
            width: 100%;
            max-width: 800px;
            margin-bottom: 20px;
        }

        .factory {
            background-color: var(--panel-bg);
            padding: 20px;
            border-radius: 10px;
            width: 45%;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
        }

        .factory h2 {
            text-align: center;
            margin-top: 0;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 10px;
        }

        .queue {
            display: flex;
            gap: 10px;
            height: 100px;
            background-color: #383a59;
            border-radius: 5px;
            padding: 10px;
            align-items: center;
            justify-content: flex-start;
        }

        .unit {
            width: 80px;
            height: 80px;
            background-color: #44475a;
            border-radius: 5px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            animation: popIn 0.2s ease-out;
            position: relative;
        }

        .unit span {
            font-size: 14px;
            margin-top: 5px;
        }

        @keyframes popIn {
            0% { transform: scale(0); }
            100% { transform: scale(1); }
        }

        .log-container {
            background-color: var(--panel-bg);
            width: 100%;
            max-width: 800px;
            height: 200px;
            border-radius: 10px;
            padding: 15px;
            overflow-y: auto;
            box-sizing: border-box;
            font-family: monospace;
            box-shadow: inset 0 0 10px rgba(0,0,0,0.5);
        }

        .log-entry { margin: 5px 0; }
        .log-header { color: var(--accent); font-weight: bold; margin-top: 15px;}
        .log-success { color: var(--success); }
        .log-warning { color: var(--warning); }
        .log-error { color: var(--error); }
        .log-info { color: #8be9fd; }
    </style>
</head>
<body>

    <h1>🏰 HW3-1 手動派單系統</h1>

    <div class="dashboard">
        <div class="status-panel">
            <h3>目前黃金</h3>
            <div class="gold-display" id="goldDisplay">💰 150</div>
        </div>
        <div class="status-panel">
            <h3>當前進度</h3>
            <div style="font-size: 24px; font-weight: bold;" id="roundDisplay">準備開始</div>
        </div>
    </div>

    <div class="action-panel">
        <h3>下達指令</h3>
        <div class="button-group">
            <button onclick="playTurn('劍士')">⚔️ 劍士 ($20)</button>
            <button onclick="playTurn('弓手')">🏹 弓手 ($30)</button>
            <button onclick="playTurn('騎士')">🐎 騎士 ($50)</button>
            <button onclick="playTurn('投石車')">🪨 投石車 ($40)</button>
            <button class="btn-skip" onclick="playTurn(null)">⏳ 跳過本回合</button>
            <button class="btn-reset" onclick="resetGame()">🔄 重置遊戲</button>
        </div>
    </div>

    <div class="factory-container">
        <div class="factory">
            <h2>A 廠 (容量: 2)</h2>
            <div class="queue" id="queueA"></div>
        </div>
        <div class="factory">
            <h2>B 廠 (容量: 2)</h2>
            <div class="queue" id="queueB"></div>
        </div>
    </div>

    <div class="log-container" id="logBox">
        <div style="color: gray;">系統初始化完畢，請點擊上方按鈕下達指令...</div>
    </div>

    <script>
        // 初始狀態設定
        const initialGold = 150;
        let player_gold = initialGold;
        let barracks_A = [];
        let barracks_B = [];
        let round_num = 0;

        // 兵種價目表與素材
        const unitData = {
            "劍士": { cost: 20, emoji: "⚔️" },
            "弓手": { cost: 30, emoji: "🏹" },
            "騎士": { cost: 50, emoji: "🐎" },
            "投石車": { cost: 40, emoji: "🪨" }
        };

        // 取得 DOM 元素
        const goldDisplay = document.getElementById('goldDisplay');
        const roundDisplay = document.getElementById('roundDisplay');
        const queueA = document.getElementById('queueA');
        const queueB = document.getElementById('queueB');
        const logBox = document.getElementById('logBox');

        function log(msg, type = '') {
            const div = document.createElement('div');
            div.className = `log-entry ${type}`;
            div.innerText = msg;
            logBox.appendChild(div);
            logBox.scrollTop = logBox.scrollHeight;
        }

        function renderQueues() {
            goldDisplay.innerText = `💰 ${player_gold}`;
            roundDisplay.innerText = `第 ${round_num} 回合`;

            queueA.innerHTML = '';
            barracks_A.forEach(item => {
                queueA.innerHTML += `<div class="unit">${item.emoji}<span>${item.unit}</span></div>`;
            });

            queueB.innerHTML = '';
            barracks_B.forEach(item => {
                queueB.innerHTML += `<div class="unit">${item.emoji}<span>${item.unit}</span></div>`;
            });
        }

        // 玩家點擊按鈕觸發回合
        function playTurn(selectedUnitName) {
            log(`\n--- 第 ${round_num} 回合 ---`, "log-header");

            // 1. Dequeue 階段：偶數回合出列
            if (round_num % 2 === 0) {
                if (barracks_A.length > 0) {
                    let finished = barracks_A.shift();
                    log(`A 廠生產完成: ${finished.unit} 出列！`, "log-success");
                } else {
                    log("A 廠沒東西可做 (Underflow 防護成功)", "log-warning");
                }

                if (barracks_B.length > 0) {
                    let finished = barracks_B.shift();
                    log(`B 廠生產完成: ${finished.unit} 出列！`, "log-success");
                } else {
                    log("B 廠沒東西可做 (Underflow 防護成功)", "log-warning");
                }
            }

            // 2. Enqueue 階段：處理玩家的新訂單
            if (selectedUnitName === null) {
                log("玩家本回合無動作，單純推進時間", "log-info");
            } else {
                let unitInfo = unitData[selectedUnitName];
                let unit = selectedUnitName;
                let cost = unitInfo.cost;

                if (player_gold < cost) {
                    log(`黃金不足，無法生產 ${unit}`, "log-error");
                } else {
                    // Overflow 防禦
                    if (barracks_A.length >= 2 && barracks_B.length >= 2) {
                        log(`產線全滿！${unit} 訂單拒絕`, "log-error");
                    } else {
                        player_gold -= cost;
                        // 負載平衡邏輯
                        if (barracks_A.length <= barracks_B.length && barracks_A.length < 2) {
                            barracks_A.push({ unit: unit, emoji: unitInfo.emoji });
                            log(`${unit} 分派至 A 廠 (剩餘黃金: ${player_gold})`, "log-success");
                        } else {
                            barracks_B.push({ unit: unit, emoji: unitInfo.emoji });
                            log(`${unit} 分派至 B 廠 (剩餘黃金: ${player_gold})`, "log-success");
                        }
                    }
                }
            }

            // 更新內部資料與畫面
            let aNames = barracks_A.map(u => `'${u.unit}'`);
            let bNames = barracks_B.map(u => `'${u.unit}'`);
            log(`A: [${aNames.join(', ')}] | B: [${bNames.join(', ')}]`, "log-info");
            
            renderQueues();
            round_num++; // 回合結束，推進時間
        }

        function resetGame() {
            player_gold = initialGold;
            barracks_A = [];
            barracks_B = [];
            round_num = 0;
            logBox.innerHTML = '<div style="color: gray;">遊戲已重置，請點擊上方按鈕下達指令...</div>';
            renderQueues();
            roundDisplay.innerText = `準備開始`;
        }

        // 初始化
        renderQueues();
        roundDisplay.innerText = `準備開始`;
    </script>
</body>
</html>
